APP_NAME=DevTracker API
APP_ENV=production
APP_PORT=8080
APP_BASE_PATH=/api
APP_BODY_LIMIT=4194304
APP_READ_TIMEOUT=10s
APP_WRITE_TIMEOUT=10s
APP_SHUTDOWN_TIMEOUT=10s

DB_HOST=postgres
DB_PORT=5432
DB_USER=devtracker
DB_PASSWORD=devtrackerpass
DB_NAME=devtracker
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h
DB_SLOW_THRESHOLD=200ms
DB_RUN_MIGRATIONS=true

POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

JWT_SECRET=replace-this-with-a-long-random-production-secret
JWT_ISSUER=devtracker
JWT_ACCESS_TOKEN_TTL=24h
